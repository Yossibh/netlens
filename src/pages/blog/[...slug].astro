---
import Layout from '../../components/Layout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import { readingTimeMinutes, formatDate } from '../../lib/blog';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

type Props = { post: CollectionEntry<'blog'> };
const { post } = Astro.props as Props;
const { Content } = await post.render();
const url = `https://netrecon.pages.dev/blog/${post.slug}/`;
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.pubDate instanceof Date ? post.data.pubDate.toISOString() : post.data.pubDate,
  author: {
    '@type': 'Person',
    name: post.data.author ?? 'Yossi Ben Hagai',
    url: 'https://yossibh.github.io/',
    sameAs: [
      'https://yossibh.github.io/',
      'https://github.com/Yossibh',
      'https://www.linkedin.com/in/yossibenhagai/',
    ],
  },
  publisher: {
    '@type': 'Organization',
    name: 'netrecon',
    url: 'https://netrecon.pages.dev',
  },
  mainEntityOfPage: url,
  url,
  keywords: post.data.tags,
};
---
<Layout
  title={`${post.data.title} - netrecon`}
  description={post.data.description}
  ogType="article"
  canonical={url}
  schema={articleSchema}
>
  <article class="post">
    <h1>{post.data.title}</h1>
    <div class="meta">
      {formatDate(post.data.pubDate)} · {post.data.author} · {readingTimeMinutes(post)} min read
      {post.data.tags.length > 0 && (
        <span class="tag-row">
          {post.data.tags.map((t) => <a class="tag" href={`/blog/tags/${t}/`}>{t}</a>)}
        </span>
      )}
    </div>
    <Content />
    <p class="post-footer mono"><a href="/blog">- back to all posts</a></p>
  </article>
</Layout>

